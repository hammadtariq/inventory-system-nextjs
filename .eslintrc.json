{
  "plugins": ["@next/next", "react-hooks"],
  "extends": ["plugin:@next/next/core-web-vitals-legacy", "prettier"],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "rules": {
    "no-const-assign": 2,
    "no-unused-vars": 1
  }
}
